# ─── Telegram User API (https://my.telegram.org) ────────────────────────────
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+79001234567

# ─── Мониторинг и администраторы ────────────────────────────────────────────
# Comma-separated chat IDs для мониторинга парсером (оставьте пустым = все чаты)
MONITORED_CHATS=-1001234567890,-1009876543210
# Telegram user IDs администраторов (comma-separated)
ADMIN_IDS=12345678,87654321
# Telegram username для эскалации (без @)
ADMIN_TELEGRAM_USERNAME=your_username_here

# ─── Supervisor Bot (Gwen) ───────────────────────────────────────────────────
# Токен бота-супервайзера (получить у @BotFather)
SUPERVISOR_BOT_TOKEN=your_bot_token_here
# Chat ID куда Gwen отправляет уведомления и лиды (обычно ID администратора)
SUPERVISOR_CHAT_ID=12345678
# Автоматический аутрич без подтверждения (true/false)
AUTO_OUTREACH=false

# ─── Пути к файлам ──────────────────────────────────────────────────────────
# Путь к SQLite БД с вакансиями (по умолчанию: data/db/vacancies.db)
VACANCY_DB_PATH=data/db/vacancies.db

# ─── OpenRouter AI (https://openrouter.ai/keys) ─────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=deepseek/deepseek-chat

# ─── Локальная LLM (Ollama) ──────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=qwen2.5:3b

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///data/db/bot_data.db

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── CORS (дашборд) ──────────────────────────────────────────────────────────
# Comma-separated список разрешённых origin для дашборда
CORS_ORIGINS=http://localhost:8000,http://localhost:3000,http://127.0.0.1:8000

# ─── Логирование и режим разработки ─────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG=false
